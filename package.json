{
  "name": "font-awesome-icons",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --project example-app --host 0.0.0.0",
    "start:standalone": "ng serve --project example-app-standalone --host 0.0.0.0",
    "build": "npm run build:lib && npm run build:app && npm run build:standalone",
    "build:app": "npm run ng build example-app",
    "build:standalone": "npm run ng build example-app-standalone",
    "build:lib": "npm run build:lib:pre && npm run ng build font-awesome-icons-lib && npm run build:lib:post",
    "build:lib:pre": "npm run icons",
    "build:lib:post": "cpx 'projects/font-awesome-icons-lib/src/icons/**/*.{d.ts,js,mjs}' dist/font-awesome-icons/icons",
    "test": "npm run test:lib && npm run test:example && npm run test:standalone",
    "test:docker": "npm run test:lib:docker && npm run test:example:docker && npm run test:standalone:docker",
    "test:standalone": "ng test example-app-standalone --no-watch --progress=false --code-coverage --browsers ChromeHeadless",
    "test:standalone:docker": "ng test example-app-standalone --no-watch --progress=false --code-coverage --browsers ChromeDocker",
    "test:lib": "ng test font-awesome-icons-lib --no-watch --progress=false --code-coverage --browsers ChromeHeadless",
    "test:lib:docker": "ng test font-awesome-icons-lib --no-watch --progress=false --code-coverage --browsers ChromeDocker",
    "test:example": "ng test example-app --no-watch --progress=false --code-coverage --browsers ChromeHeadless",
    "test:example:docker": "ng test example-app --no-watch --progress=false --code-coverage --browsers ChromeDocker",
    "icons": "node ./util/rename-icon.js && svg-to-ts-files -s /*.svg -o -f icons && node ./util/unrename-icon.js",
    "lint": "prettier --check \"**/*.{ts,js,html,scss,json,md}\" && ng lint",
    "lint:fix": "prettier --write \"**/*.{ts,js,html,scss,json,md}\" && ng lint --fix",
    "e2e": "ng e2e"
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^22.0.6",
    "@angular/compiler": "^22.0.6",
    "@angular/core": "^22.0.6",
    "@angular/forms": "^22.0.6",
    "@angular/platform-browser": "^22.0.6",
    "@angular/router": "^22.0.6",
    "rxjs": "~7.8.2",
    "svg-to-ts": "^12.0.0",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular/build": "^22.0.6",
    "@angular/cli": "^22.0.6",
    "@angular/compiler-cli": "^22.0.6",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@types/jasmine": "~6.0.0",
    "@types/jasminewd2": "~2.0.13",
    "@types/node": "^25.9.2",
    "angular-eslint": "22.0.0",
    "cpx": "^1.5.0",
    "eslint": "^10.6.0",
    "istanbul-lib-instrument": "^6.0.3",
    "jasmine-core": "~6.2.0",
    "jasmine-spec-reporter": "~7.0.0",
    "karma": "^6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "^2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "^2.1.0",
    "ng-packagr": "^22.0.1",
    "prettier": "^3.9.5",
    "rxjs-marbles": "^7.0.1",
    "ts-node": "~10.9.2",
    "typescript": "~6.0.3",
    "typescript-eslint": "8.63.0"
  }
}
